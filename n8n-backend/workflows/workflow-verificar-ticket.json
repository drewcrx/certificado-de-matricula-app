    {
      "parameters": {
        "operation": "executeQuery",
        "resource": "database",
        "query": "SELECT id FROM otp_codigos WHERE cedula = $1 AND codigo_hash = encode(digest($2, 'sha256'), 'hex') AND usado = FALSE AND expira_en > NOW() AND canal = 'chatbot' ORDER BY creado_en DESC LIMIT 1",
        "options": {
          "queryReplacement": "={{ [$json.body.cedula, $json.body.ticket] }}"
        }
      },
      "id": "d3333333-3333-4333-8333-333333333333",
      "name": "Buscar Ticket Vigente (Postgres)",
      "type": "n8n-nodes-base.postgres",
