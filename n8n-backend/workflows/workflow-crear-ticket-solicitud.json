      "parameters": {
        "jsCode": "const ticket = $('Generar Código (Postgres)').item.json;\nconst asignacion = $json;\nconst tipoTramite = $('Webhook').item.json.body.tipoTramite;\n\nreturn [{\n  json: {\n    id: ticket.id,\n    codigo: ticket.codigo,\n    creado_en: ticket.creado_en,\n    responsable_id: asignacion.responsable_id ?? null,\n    payloadCreado: JSON.stringify({ tipo: tipoTramite, codigo: ticket.codigo, ticket_id: String(ticket.id) }),\n    payloadAsignado: JSON.stringify({ ticket_id: String(ticket.id), responsable_id: asignacion.responsable_id != null ? String(asignacion.responsable_id) : null })\n  }\n}];"
      },
