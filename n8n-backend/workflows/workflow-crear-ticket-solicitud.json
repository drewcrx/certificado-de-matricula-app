    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO tickets_solicitud (id, cedula, tipo_tramite, estado)\nVALUES (\n  'TCK-' || EXTRACT(YEAR FROM NOW()) || '-' || LPAD(nextval('tickets_solicitud_seq')::text, 6, '0'),\n  $1, $2, 'EN_PROCESO'\n)\nRETURNING id, cedula, tipo_tramite, estado, fecha_solicitud",
        "additionalFields": {
          "queryParams": "={{ [$('Webhook').item.json.body.cedula, $('Webhook').item.json.body.tipoTramite] }}"
        }
      },
