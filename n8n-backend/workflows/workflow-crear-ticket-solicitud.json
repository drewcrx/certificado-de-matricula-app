    {
      "parameters": {
        "jsCode": "const fecha = new Date($json.fecha_solicitud);\nconst fechaSolicitud = fecha.toLocaleDateString('es-EC', {\n  year: 'numeric', month: 'long', day: '2-digit'\n});\n\nreturn [{\n  json: {\n    id: $json.id,\n    tipo: $('Buscar Tipo de Trámite (Postgres)').item.json.nombre,\n    estado: $json.estado,\n    fechaSolicitud\n  }\n}];"
      },
