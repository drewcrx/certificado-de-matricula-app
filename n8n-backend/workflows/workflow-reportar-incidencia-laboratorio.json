        "query": "SELECT d.cedula, d.nombre_docente AS \"nombreDocente\", up.id AS \"profesorId\" FROM docentes d JOIN usuarios_panel up ON up.cedula = d.cedula JOIN roles r ON r.id = up.rol_id AND r.codigo = 'PROFESOR' WHERE d.cedula = $1",
