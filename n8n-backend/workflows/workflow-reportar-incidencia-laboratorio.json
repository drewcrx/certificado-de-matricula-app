    {
      "parameters": {
        "jsCode": "const alerta = $('Generar Código (Postgres)').item.json;\nconst fecha = new Date(alerta.creado_en);\nconst fechaReporte = fecha.toLocaleDateString('es-EC', {\n  year: 'numeric', month: 'long', day: '2-digit', timeZone: 'America/Guayaquil'\n});\n\nreturn [{\n  json: {\n    codigo: alerta.codigo,\n    laboratorio: $('Webhook').item.json.body.laboratorioCodigo,\n    descripcion: $('Webhook').item.json.body.descripcion,\n    estado: 'Pendiente',\n    fechaReporte,\n    tieneFoto: !!$('Webhook').item.json.body.fotoBase64,\n    correoResponsable: $('Buscar Responsable (Postgres)').item.json.correoResponsable ?? null,\n    nombreResponsable: $('Buscar Responsable (Postgres)').item.json.nombreResponsable ?? null,\n    nombreDocente: $('Buscar Docente Válido (Postgres)').item.json.nombreDocente\n  }\n}];"
      },
