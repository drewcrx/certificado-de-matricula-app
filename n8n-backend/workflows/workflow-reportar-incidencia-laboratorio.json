    {
      "parameters": {
        "jsCode": "const body = $('Webhook').item.json.body;\nconst mime = (body.fotoMime === 'image/png') ? 'image/png' : 'image/jpeg';\nconst extension = mime === 'image/png' ? 'png' : 'jpg';\nconst nombreArchivo = `${Date.now()}-${Math.random().toString(36).slice(2, 10)}.${extension}`;\nconst tamanoBytes = Buffer.from(body.fotoBase64, 'base64').length;\n\nreturn [{\n  json: { nombreArchivo, mime, tamanoBytes },\n  binary: {\n    data: {\n      data: body.fotoBase64,\n      mimeType: mime,\n      fileName: nombreArchivo\n    }\n  }\n}];"
      },
      "id": "ihhhhhh2-hhhh-4hhh-8hhh-hhhhhhhhhhh2",
      "name": "Preparar Foto (Binario)",
