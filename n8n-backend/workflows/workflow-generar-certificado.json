              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "b4444444-4444-4444-8444-444444444444",
      "name": "¿Está matriculado?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [720, 0]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT codigo_unico AS \"codigoUnico\", cedula, nombre_completo AS \"nombreCompleto\", carrera, nivel, periodo_actual AS \"periodoActual\", fecha_emision AS \"fechaEmision\", url_verificacion AS \"urlVerificacion\" FROM certificados_matricula WHERE cedula = $1 AND periodo_actual = $2",
        "additionalFields": {
          "queryParams": "={{ [$json.cedula, $json.periodoActual] }}"
        }
      },
      "id": "b9999999-9999-4999-8999-999999999999",
