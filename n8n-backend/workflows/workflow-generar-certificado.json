      "id": "baaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa",
      "name": "¿Ya existe certificado?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1240, -220]
    },
    {
      "parameters": {
        "jsCode": "const anio = new Date().getFullYear();\nconst aleatorio = Math.random().toString(36).slice(2, 10).toUpperCase();\nconst codigoUnico = `MAT-${anio}-${aleatorio}`;\n// TODO produccion: reemplazar por UUID real. La unicidad real la garantiza\n// el UNIQUE(cedula, periodo_actual) de la tabla + el chequeo previo de\n// \"Buscar Certificado Existente\".\n\nconst nombreCompleto = `${$json.nombres} ${$json.apellidos}`;\nconst fechaEmision = new Date().toLocaleDateString('es-EC', {\n  year: 'numeric', month: 'long', day: '2-digit'\n});\nconst urlVerificacion = `https://verificacion.tudominio.edu.ec/certificados/${codigoUnico}`;\n\nreturn [{\n  json: {\n    ...$json,\n    codigoUnico,\n    nombreCompleto,\n    fechaEmision,\n    urlVerificacion\n  }\n}];"
      },
      "id": "b5555555-5555-4555-8555-555555555555",
      "name": "Generar Código Único",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [980, -20]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO certificados_matricula (codigo_unico, cedula, nombre_completo, carrera, nivel, periodo_actual, url_verificacion)\nVALUES ($1, $2, $3, $4, $5, $6, $7)",
        "additionalFields": {
          "queryParams": "={{ [$json.codigoUnico, $json.cedula, $json.nombreCompleto, $json.carrera, $json.nivel, $json.periodoActual, $json.urlVerificacion] }}"
        }
      },
      "id": "b6666666-6666-4666-8666-666666666666",
