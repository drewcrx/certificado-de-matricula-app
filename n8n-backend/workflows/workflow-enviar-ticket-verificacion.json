        "responseBody": "={{ { \"correoEnmascarado\": $json.correoEnmascarado } }}",
        "options": {
          "responseCode": 200
        }
      },
      "id": "c8888888-8888-4888-8888-888888888888",
      "name": "Responder: Ticket enviado",
