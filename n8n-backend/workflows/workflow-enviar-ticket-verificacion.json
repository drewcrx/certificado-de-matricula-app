    {
      "parameters": {
        "jsCode": "const ticket = Math.floor(100000 + Math.random() * 900000).toString();\n\nconst usuario = $json.correoInstitucional.split('@')[0];\nconst dominio = $json.correoInstitucional.split('@')[1];\nconst visible = usuario.slice(0, 2);\nconst correoEnmascarado = `${visible}${'*'.repeat(Math.max(usuario.length - 2, 3))}@${dominio}`;\n\nreturn [{\n  json: {\n    ...$json,\n    ticket,\n    correoEnmascarado\n  }\n}];"
      },
      "id": "c5555555-5555-4555-8555-555555555555",
      "name": "Generar Ticket",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        980,
        -120
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "resource": "database",
        "query": "INSERT INTO otp_codigos (cedula, correo, codigo_hash, canal, expira_en) VALUES ($1, $2, encode(digest($3, 'sha256'), 'hex'), 'chatbot', NOW() + INTERVAL '10 minutes')",
        "options": {
          "queryReplacement": "={{ [$json.cedula, $json.correoInstitucional, $json.ticket] }}"
        }
      },
      "id": "c6666666-6666-4666-8666-666666666666",
      "name": "Guardar Ticket (Postgres)",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        1240,
        -120
      ],
      "credentials": {
        "postgres": {
          "id": "REEMPLAZAR",
          "name": "REEMPLAZAR con credenciales reales"
        }
      }
    },
    {
      "parameters": {
        "fromEmail": "no-responder@yavirac.edu.ec",
        "toEmail": "={{ $('Generar Ticket').item.json.correoInstitucional }}",
        "subject": "Tu ticket de verificación - YaviBot",
        "emailFormat": "text",
        "text": "={{ \"Hola \" + $('Generar Ticket').item.json.nombres + \",\\n\\nTu ticket de verificación es: \" + $('Generar Ticket').item.json.ticket + \"\\n\\nEste ticket expira en 10 minutos. Si no lo solicitaste, ignora este correo.\" }}"
      },
      "id": "c7777777-7777-4777-8777-777777777777",
