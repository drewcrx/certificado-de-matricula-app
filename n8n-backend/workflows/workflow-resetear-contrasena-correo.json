    {
      "parameters": {
        "jsCode": "// Contraseña temporal segura: 14 caracteres, mayúsculas + minúsculas + dígitos + símbolo,\n// generada del lado del servidor (nunca la manda el cliente).\nconst MAYUS = 'ABCDEFGHJKLMNPQRSTUVWXYZ';\nconst MINUS = 'abcdefghijkmnpqrstuvwxyz';\nconst DIGITOS = '23456789';\nconst SIMBOLOS = '!@#$%&*';\nconst TODOS = MAYUS + MINUS + DIGITOS + SIMBOLOS;\n\nfunction aleatorio(alfabeto) {\n  return alfabeto[Math.floor(Math.random() * alfabeto.length)];\n}\n\nlet clave = aleatorio(MAYUS) + aleatorio(MINUS) + aleatorio(DIGITOS) + aleatorio(SIMBOLOS);\nfor (let i = clave.length; i < 14; i++) {\n  clave += aleatorio(TODOS);\n}\n// Mezclar para que los 4 primeros caracteres \"garantizados\" no queden siempre al inicio.\nclave = clave.split('').sort(() => Math.random() - 0.5).join('');\n\nreturn [{ json: { passwordTemporal: clave } }];"
      },
      "id": "e9999999-9999-4999-8999-999999999999",
