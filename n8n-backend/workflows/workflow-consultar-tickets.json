    {
      "parameters": {
        "operation": "executeQuery",
        "resource": "database",
        "query": "SELECT t.codigo AS id, ts.nombre AS tipo, t.estado, t.creado_en AS fecha_solicitud FROM tickets t JOIN tipos_solicitud ts ON ts.id = t.tipo_solicitud_id JOIN estudiantes e ON e.id = t.estudiante_id WHERE e.cedula = $1 ORDER BY t.creado_en DESC",
        "options": {
          "queryReplacement": "={{ [ $('Webhook').item.json.body.cedula ] }}"
        }
      },
