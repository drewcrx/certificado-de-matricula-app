    {
      "parameters": {
        "operation": "executeQuery",
        "resource": "database",
        "query": "SELECT t.codigo AS id, ts.nombre AS tipo, t.estado, t.creado_en AS fecha_solicitud FROM tickets t JOIN tipos_solicitud ts ON ts.id = t.tipo_solicitud_id JOIN estudiantes e ON e.id = t.estudiante_id WHERE e.cedula = $1 ORDER BY t.creado_en DESC",
        "options": {
          "queryReplacement": "={{ [ $json.body.cedula ] }}"
        }
      },
      "id": "e3333333-3333-4333-8333-333333333333",
      "name": "Buscar Tickets (Postgres)",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        460,
        0
      ],
      "alwaysOutputData": true,
      "credentials": {
        "postgres": {
          "id": "REEMPLAZAR",
          "name": "REEMPLAZAR con credenciales reales"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const MAPA_ESTADO = {\n  'Pendiente': 'EN_PROCESO',\n  'En Proceso': 'EN_PROCESO',\n  'Resuelto': 'COMPLETADO'\n};\n\nconst tickets = $input.all()\n  .filter(item => item.json && item.json.id)\n  .map(item => {\n    const fecha = new Date(item.json.fecha_solicitud);\n    const fechaSolicitud = fecha.toLocaleDateString('es-EC', {\n      year: 'numeric', month: 'long', day: '2-digit', timeZone: 'America/Guayaquil'\n    });\n    return {\n      id: item.json.id,\n      tipo: item.json.tipo,\n      estado: MAPA_ESTADO[item.json.estado] || 'EN_PROCESO',\n      fechaSolicitud\n    };\n  });\n\nreturn [{ json: { tickets } }];"
      },
